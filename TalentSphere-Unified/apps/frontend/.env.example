# ===========================================
# TALENTSPHERE FRONTEND SUPABASE CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to Git!

# -------------------------------------------
# Supabase Configuration (REQUIRED)
# -------------------------------------------
# Get these from: https://app.supabase.com/project/tvulrziizvakwzxfvdwv/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://tvulrziizvakwzxfvdwv.supabase.co

# Supabase ANON/Public key (for client-side use)
# Replace with your actual key from Supabase dashboard
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# -------------------------------------------
# Storage Buckets (Optional)
# -------------------------------------------
VITE_SUPABASE_STORAGE_BUCKET_AVATARS=avatars
VITE_SUPABASE_STORAGE_BUCKET_RESUMES=resumes
VITE_SUPABASE_STORAGE_BUCKET_LOGOS=company-logos

# -------------------------------------------
# Application Configuration
# -------------------------------------------
VITE_APP_NAME=TalentSphere
VITE_APP_URL=http://localhost:5173

# -------------------------------------------
# Feature Flags (Optional)
# -------------------------------------------
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_GAMIFICATION=true
VITE_ENABLE_LMS=true
