{
  "name": "talentsphere-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "docs": "typedoc \"src/**/*.ts\" \"src/**/*.tsx\" --out ../docs/frontend/html --excludePrivate --name \"TalentSphere Frontend\"",
    "docs:serve": "npx serve ../docs/frontend/html -l 3001",
    "generate-docs": "typedoc \"src/**/*.ts\" \"src/**/*.tsx\" --out ../docs/frontend/html --excludePrivate --name \"TalentSphere Frontend\""
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@supabase/supabase-js": "^2.105.3",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "5.0.0",
    "autoprefixer": "^10.4.27",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15.14.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
