  "schemaVersion": 1,
  "updatedAt": "2026-06-27",
  "description": "Source-validated data ownership matrix for Supabase/Postgres tables observed in frontend direct access and reviewed SQL files.",
  "domains": {
    "identity": {
      "owner": "auth-boundary-decision",
      "note": "Supabase Auth and auth-service ownership remains unresolved."
    },
    "profile": {
      "owner": "profile-domain",
      "note": "Profile-service or a generated Supabase repository must own durable profile writes after the schema authority decision."
    },
    "jobs": {
      "owner": "job-domain",
      "note": "Job-service should own job lifecycle and publishing policy after migration."
    },
    "applications": {
      "owner": "application-domain",
      "note": "Application-service should own application status lifecycle, drafts, and append-only events."
    },
    "recruiting": {
      "owner": "recruiting-domain",
      "note": "Recruiter candidate review data needs backend-owned permissions and audit."
    },
    "ai": {
      "owner": "ai-domain",
      "note": "AI outputs remain review-first suggestions until provider and persistence policy are finalized."
    },
    "analytics": {
      "owner": "analytics-domain",
      "note": "Append-only privacy-bounded analytics and audit ingestion."
    },
    "networking": {
      "owner": "networking-domain",
      "note": "Networking-service should own graph and request lifecycle."
    },
    "messaging": {
      "owner": "messaging-domain",
      "note": "Messaging-service and orphaned chat-service boundary remains an open decision."
    },
    "learning": {
      "owner": "lms-domain",
      "note": "LMS service should own course, enrollment, and progress writes."
    },
    "challenges": {
      "owner": "challenge-domain",
      "note": "Challenge-service should own submissions and judging lifecycle."
    },
    "gamification": {
      "owner": "gamification-domain",
      "note": "Gamification-service should own XP, badges, leaderboard, and achievements."
    },
    "notifications": {
      "owner": "notification-domain",
      "note": "Notification-service and scheduler jobs should own inbox and digest state."
    },
    "billing": {
      "owner": "payment-domain",
      "note": "Payment-service should own provider-backed checkout, webhooks, subscriptions, and invoices."
    },
    "admin": {
      "owner": "admin-ops-domain",
      "note": "Admin settings and audit logs require backend-owned authorization and redaction."
    }
  },
